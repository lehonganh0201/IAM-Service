# =========================
# Application
# =========================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# =========================
# Identity Provider
# SELF or KEYCLOAK
# =========================
APP_IDENTITY_PROVIDER_TYPE=SELF

# =========================
# Database
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_service
DB_USERNAME=iam_user
DB_PASSWORD=iam_password

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================
# Self-IDP JWT
# Use a long random secret in real environments
# =========================
JWT_SECRET=change-me-change-me-change-me-change-me-change-me
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# =========================
# Local demo admin
# Do not use this password in production
# =========================
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=Admin@123456

# =========================
# Keycloak
# =========================
KEYCLOAK_SERVER_URL=http://localhost:8081
KEYCLOAK_REALM=iam-realm
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/iam-realm
KEYCLOAK_USER_CLIENT_ID=iam-user-client
KEYCLOAK_USER_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_ID=iam-admin-client
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me
KEYCLOAK_REDIRECT_URI=http://localhost:3000/callback

# =========================
# Mail
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change-me@example.com
MAIL_PASSWORD=change-me

# =========================
# Cloudinary
# =========================
CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me

# =========================
# Logging
# =========================
LOG_LEVEL=INFO